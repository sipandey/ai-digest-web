# Supabase
NEXT_PUBLIC_SUPABASE_URL=
# Non-NEXT_PUBLIC version required for all server-side routes (supabaseAdmin).
# NEXT_PUBLIC_SUPABASE_URL is not a substitute in the Node.js server context.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Note: NEXT_PUBLIC_SUPABASE_ANON_KEY is NOT used by the web app.
# It is only needed as a GitHub Actions secret (SUPABASE_ANON_KEY) for the
# pipeline check job. Do not add it to Vercel or web/.env.local.

# Clerk auth (email-signup users)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Guest session (Notion-first users — no Clerk account required)
# Generate with: openssl rand -hex 32
GUEST_SESSION_SECRET=

# Application-layer encryption key for Notion credentials stored in user_configs.
# Must be exactly 64 hex characters (32 bytes = AES-256).
# Generate with: openssl rand -hex 32
# Required in: web app (Next.js) AND pipeline (Python)
NOTION_TOKEN_ENCRYPTION_KEY=

# App URL — used for metadataBase (OG tags, Twitter cards).
# Set to the canonical origin for each environment, e.g.:
#   production:  https://aidigest.app
#   staging:     https://staging.aidigest.app
#   local:       http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Upstash Redis — distributed rate limiting across Vercel serverless instances.
# Copy from Upstash Console → your database → REST API tab.
# If absent, falls back to per-instance in-memory rate limiting (dev only).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# OpenAI (pipeline only — not needed in web/.env.local)
OPENAI_API_KEY=

# Pipeline trigger mode:
# - direct: spawn the local Python pipeline from the Next.js app
# - github_actions: dispatch the GitHub Actions workflow
PIPELINE_TRIGGER_MODE=direct

# Direct mode only
PIPELINE_PYTHON_BIN=python3

# GitHub Actions mode only
PIPELINE_GITHUB_TOKEN=
PIPELINE_GITHUB_REPOSITORY=
PIPELINE_GITHUB_WORKFLOW_ID=daily_pipeline.yml
PIPELINE_GITHUB_REF=main

# System-wide daily cap on total pipeline runs across all users.
# Protects against runaway OpenAI spend. Default: 200. Override without a deploy.
# SYSTEM_DAILY_RUN_BUDGET=200
